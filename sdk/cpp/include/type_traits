#pragma once
// Freestanding shim: only the subset used by abi.hpp static_asserts.
// __underlying_type and __is_same are clang compiler builtins.
namespace std {

template <class T, class U>
struct is_same { static constexpr bool value = false; };
template <class T>
struct is_same<T, T> { static constexpr bool value = true; };
template <class T, class U>
inline constexpr bool is_same_v = is_same<T, U>::value;

template <class E>
struct underlying_type { using type = __underlying_type(E); };
template <class E>
using underlying_type_t = typename underlying_type<E>::type;

} // namespace std
